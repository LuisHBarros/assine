# JWT
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=assine
MINIO_SECRET_KEY=assine123
MINIO_BUCKET=invoices
