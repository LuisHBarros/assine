# Copy this file to `.env` before running Docker Compose.
# Defaults are chosen for local development only.

# RabbitMQ
RABBITMQ_USER=assine
RABBITMQ_PASS=assine

# Auth database
AUTH_DB_NAME=auth
AUTH_DB_USER=assine
AUTH_DB_PASS=assine

# Billing database
BILLING_DB_NAME=billing
BILLING_DB_USER=assine
BILLING_DB_PASS=assine

# Subscriptions database
SUBSCRIPTIONS_DB_NAME=subscriptions
SUBSCRIPTIONS_DB_USER=assine
SUBSCRIPTIONS_DB_PASS=assine

# Access database
ACCESS_DB_NAME=access
ACCESS_DB_USER=assine
ACCESS_DB_PASS=assine

# Fiscal database
FISCAL_DB_NAME=fiscal
FISCAL_DB_USER=assine
FISCAL_DB_PASS=assine

# Auth service
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
JWT_PRIVATE_KEY=change-me
JWT_PUBLIC_KEY=change-me
MAGIC_LINK_BASE_URL=http://localhost:8086/auth/magic-link/validate

# Billing service
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_xxx
SUBSCRIPTIONS_SERVICE_URL=http://subscriptions:8081

# Notifications service
SENDGRID_API_KEY=SG.dummy
SENDGRID_FROM_EMAIL=no-reply@assine.com.br
SENDGRID_FROM_NAME=Assine

# Fiscal service and storage
NUVEM_FISCAL_CLIENT_ID=
NUVEM_FISCAL_CLIENT_SECRET=
MINIO_ACCESS_KEY=assine
MINIO_SECRET_KEY=assine-secret

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional frontend profile
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_GOOGLE_CLIENT_ID=placeholder.apps.googleusercontent.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
