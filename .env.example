# Variáveis de ambiente do projeto Assine
# Copie este arquivo para .env e preencha os valores reais

# Stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SendGrid
SENDGRID_API_KEY=SG.xxxxx

# Nuvem Fiscal
NUVEM_FISCAL_CLIENT_ID=client_id
