# Copy this file to `.env` before running Docker Compose.
# Defaults are chosen for local development only.

# RabbitMQ
RABBITMQ_USER=assine
RABBITMQ_PASS=assine

# Auth database
AUTH_DB_NAME=auth
AUTH_DB_USER=assine
AUTH_DB_PASS=assine

# Billing database
BILLING_DB_NAME=billing
BILLING_DB_USER=assine
BILLING_DB_PASS=assine

# Auth service
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
JWT_PRIVATE_KEY=change-me
JWT_PUBLIC_KEY=change-me
MAGIC_LINK_BASE_URL=http://localhost:8086/auth/magic-link/validate

# Billing service
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_xxx
SUBSCRIPTIONS_SERVICE_URL=http://subscriptions:8081

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional frontend profile
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_GOOGLE_CLIENT_ID=placeholder.apps.googleusercontent.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
